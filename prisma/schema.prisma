generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users (Admin + Client logins) ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  role          Role      @default(CLIENT)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  client        Client?
}

enum Role {
  ADMIN
  CLIENT
}

// ─── Clients (Business profiles) ────────────────────────────────────────────

model Client {
  id                String   @id @default(cuid())
  userId            String   @unique
  businessName      String
  industry          String?
  website           String?
  brandVoice        String?  @db.Text
  competitors       String?  @db.Text
  goals             String?  @db.Text
  targetAudience    String?  @db.Text
  logoUrl           String?
  socialFacebook    String?
  socialInstagram   String?
  socialLinkedin    String?
  socialGoogle      String?
  onboardingStatus  OnboardingStatus @default(INTAKE)
  planId            String?
  stripeCustomerId  String?
  stripeSubId       String?
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItems      ContentItem[]
  invoices          Invoice[]
}

enum OnboardingStatus {
  INTAKE
  PROFILE_BUILDING
  ACTIVE
  PAUSED
  CHURNED
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

// ─── Content Items ──────────────────────────────────────────────────────────

model ContentItem {
  id          String        @id @default(cuid())
  clientId    String
  platform    Platform
  contentType ContentType
  title       String?
  body        String        @db.Text
  mediaUrl    String?
  hashtags    String?
  status      ContentStatus @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@index([clientId, status])
  @@index([clientId, platform])
  @@index([scheduledAt])
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  GOOGLE_BUSINESS
  BLOG
  EMAIL
  AD_COPY
}

enum ContentType {
  SOCIAL_POST
  BLOG_ARTICLE
  EMAIL_NEWSLETTER
  EMAIL_DRIP
  AD_COPY
  STRATEGY_BRIEF
  COMPETITOR_REPORT
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

// ─── Invoices ───────────────────────────────────────────────────────────────

model Invoice {
  id              String   @id @default(cuid())
  clientId        String
  stripeInvoiceId String?  @unique
  amount          Int
  status          String   @default("pending")
  periodStart     DateTime?
  periodEnd       DateTime?
  createdAt       DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─── Plans ──────────────────────────────────────────────────────────────────

model Plan {
  id            String @id @default(cuid())
  name          String @unique
  price         Int
  stripePriceId String?
  features      String @db.Text
  description   String?
  sortOrder     Int    @default(0)
}
